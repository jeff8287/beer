---
import Base from '../layouts/Base.astro';
---

<Base title="Brew Calculators" description="Homebrew brewing calculators">
  <h1>Brew Calculators</h1>
  <p class="subtitle">Brew Day Tools</p>

  <div class="calculators">
    <section class="calc-card" id="strike">
      <h2>Strike Water Temperature</h2>
      <p class="desc">Calculate the temperature to heat your strike water.</p>
      <div class="form">
        <label>Grain Weight (kg)<input type="number" id="s-grain" value="5.8" step="0.1" /></label>
        <label>Water Volume (L)<input type="number" id="s-water" value="18" step="0.1" /></label>
        <label>Target Mash Temp (°C)<input type="number" id="s-target" value="68" step="1" /></label>
        <label>Grain Temp (°C)<input type="number" id="s-graintemp" value="22" step="1" /></label>
      </div>
      <div class="result" id="s-result"></div>
    </section>

    <section class="calc-card" id="sparge">
      <h2>Sparge Water Volume</h2>
      <p class="desc">Calculate the sparge water needed for your batch.</p>
      <div class="form">
        <label>Pre-boil Target (L)<input type="number" id="sp-preboil" value="29" step="0.5" /></label>
        <label>Strike Water (L)<input type="number" id="sp-strike" value="18" step="0.1" /></label>
        <label>Grain Weight (kg)<input type="number" id="sp-grain" value="5.8" step="0.1" /></label>
      </div>
      <div class="result" id="sp-result"></div>
    </section>

    <section class="calc-card" id="priming">
      <h2>Priming Calculator</h2>
      <p class="desc">Calculate priming sugar needed for bottle conditioning.</p>
      <div class="form">
        <label>Target CO₂ (volumes)<input type="number" id="p-co2" value="2.4" step="0.1" /></label>
        <label>Beer Temp (°C)<input type="number" id="p-temp" value="20" step="1" /></label>
        <label>Beer Volume (L)<input type="number" id="p-vol" value="19" step="0.5" /></label>
        <label>Sugar Type
          <select id="p-type">
            <option value="table">Table Sugar (Sucrose)</option>
            <option value="corn">Corn Sugar (Dextrose)</option>
            <option value="dme">DME</option>
          </select>
        </label>
      </div>
      <div class="result" id="p-result"></div>
    </section>

    <section class="calc-card" id="abv">
      <h2>ABV / Calories</h2>
      <p class="desc">Calculate ABV, attenuation, and calories from OG and FG.</p>
      <div class="form">
        <label>OG<input type="number" id="a-og" value="1.056" step="0.001" /></label>
        <label>FG<input type="number" id="a-fg" value="1.010" step="0.001" /></label>
      </div>
      <div class="result" id="a-result"></div>
    </section>

    <section class="calc-card" id="scale">
      <h2>Recipe Scaling</h2>
      <p class="desc">Scale ingredient amounts for a different batch size.</p>
      <div class="form">
        <label>Original Batch (L)<input type="number" id="sc-from" value="20" step="0.5" /></label>
        <label>New Batch (L)<input type="number" id="sc-to" value="10" step="0.5" /></label>
        <label>Original Amount (g/kg)<input type="number" id="sc-amount" value="4.025" step="0.001" /></label>
      </div>
      <div class="result" id="sc-result"></div>
    </section>
  </div>
</Base>

<script>
  function $(id: string) { return document.getElementById(id) as HTMLInputElement; }
  function val(id: string) { return parseFloat($(id).value) || 0; }

  function calcAll() {
    const ratio = val('s-water') / val('s-grain');
    const strikeTemp = (0.41 / ratio) * (val('s-target') - val('s-graintemp')) + val('s-target');
    $('s-result').innerHTML = `Heat water to <strong>${strikeTemp.toFixed(1)}°C</strong><br><span class="sub">Water/grain ratio: ${ratio.toFixed(2)} L/kg</span>`;

    const grainAbsorption = val('sp-grain') * 1.04;
    const firstRunnings = val('sp-strike') - grainAbsorption;
    const spargeNeeded = val('sp-preboil') - firstRunnings;
    $('sp-result').innerHTML = `Sparge water: <strong>${spargeNeeded.toFixed(1)}L</strong><br><span class="sub">Grain absorption: ${grainAbsorption.toFixed(1)}L · First runnings: ${firstRunnings.toFixed(1)}L</span>`;

    const temp = val('p-temp');
    const residualCO2 = 3.0378 - 0.050062 * temp + 0.00026555 * temp * temp;
    const neededCO2 = Math.max(0, val('p-co2') - residualCO2);
    const factors: Record<string, number> = { table: 4.0, corn: 4.35, dme: 5.33 };
    const sugarType = ($('p-type') as HTMLSelectElement).value;
    const sugar = neededCO2 * val('p-vol') * factors[sugarType];
    $('p-result').innerHTML = `Priming sugar: <strong>${sugar.toFixed(1)}g</strong><br><span class="sub">Residual CO₂: ${residualCO2.toFixed(2)} vols · Needed: ${neededCO2.toFixed(2)} vols</span>`;

    const og = val('a-og');
    const fg = val('a-fg');
    const abv = (og - fg) * 131.25;
    const atten = og > 1 ? ((og - fg) / (og - 1)) * 100 : 0;
    const ogP = -616.868 + 1111.14 * og - 630.272 * og * og + 135.997 * og * og * og;
    const fgP = -616.868 + 1111.14 * fg - 630.272 * fg * fg + 135.997 * fg * fg * fg;
    const re = 0.1808 * ogP + 0.8192 * fgP;
    const abw = (ogP - re) / (2.0665 - 0.010665 * ogP);
    const cal = (6.9 * abw + 4.0 * (re - 0.1)) * fg * 3.55;
    const carbsVal = (re - 0.1) * fg * 3.55;
    $('a-result').innerHTML = `ABV: <strong>${abv.toFixed(1)}%</strong> · Attenuation: <strong>${atten.toFixed(1)}%</strong><br><span class="sub">${Math.round(cal)} kcal · ${carbsVal.toFixed(1)}g carbs (per 12oz)</span>`;

    const factor = val('sc-to') / val('sc-from');
    const scaled = val('sc-amount') * factor;
    $('sc-result').innerHTML = `Scaled: <strong>${scaled.toFixed(3)}</strong><br><span class="sub">Factor: ×${factor.toFixed(2)}</span>`;
  }

  document.querySelectorAll('input, select').forEach(el =>
    el.addEventListener('input', calcAll)
  );
  calcAll();
</script>

<style>
  h1 { font-size: 2rem; color: #8b4513; }
  .subtitle { color: #888; margin-bottom: 2rem; }
  .calculators {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }
  .calc-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .calc-card h2 {
    font-size: 1.1rem;
    color: #8b4513;
    margin-bottom: 0.25rem;
    border: none;
    padding: 0;
  }
  .desc { font-size: 0.85rem; color: #888; margin-bottom: 1rem; }
  .form {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
    color: #444;
  }
  input, select {
    width: 120px;
    padding: 0.4rem 0.5rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 0.9rem;
    text-align: right;
  }
  select { text-align: left; width: 160px; }
  input:focus, select:focus {
    outline: none;
    border-color: #d4a574;
    box-shadow: 0 0 0 2px rgba(212,165,116,0.2);
  }
  .result {
    margin-top: 1rem;
    padding: 0.75rem;
    background: #faf5ef;
    border-radius: 8px;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .result :global(strong) { color: #8b4513; font-size: 1.1rem; }
  .result :global(.sub) { font-size: 0.8rem; color: #999; }
</style>
