---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { calcABV, calcIBU, calcSRM, srmToColor } from '../utils/calc';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((recipe) => ({
    params: { slug: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const d = recipe.data;
const base = import.meta.env.BASE_URL;
const { Content } = d.show_body ? await render(recipe) : { Content: null };

const abv = d.abv ?? calcABV(d.og, d.fg);
const ibu = d.ibu ?? calcIBU(d.ingredients.hops, d.og, d.batch_size_liters);
const srm = d.srm ?? calcSRM(d.ingredients.malts, d.batch_size_liters);
const srmColor = srm != null ? srmToColor(srm) : null;

const totalGrainKg = d.ingredients.malts.reduce((sum: number, m: { weight_kg: number }) => sum + m.weight_kg, 0);
---

<Base title={d.name}>
  <article>
    <a href={base} class="back">&larr; Back to list</a>

    <header>
      <h1>{d.name}</h1>
      <p class="meta">
        <span class="badge" data-status={d.status}>{d.status}</span>
        <span>{d.style}</span>
        <span>{d.batch_size_liters}L</span>
      </p>
      {d.source_url && (
        <p class="source-link">
          📖 <strong>원본 레시피:</strong>{' '}
          <a href={d.source_url} target="_blank">{d.source_label ?? d.source_url}</a>
        </p>
      )}
      {(d.collaborator_group || (d.collaborators && d.collaborators.length > 0)) && (
        <div class="collab-section">
          <span class="collab-badge">Collaborate w/{d.collaborator_group ? ` ${d.collaborator_group}` : ''}</span>
          {d.collaborators && d.collaborators.map((c: { handle: string; url?: string }) =>
            c.url
              ? <a href={c.url} target="_blank" class="collab-tag">@{c.handle}</a>
              : <span class="collab-tag">@{c.handle}</span>
          )}
        </div>
      )}
    </header>

    {d.photos && d.photos.length > 0 && (
      <section class="photos">
        {d.photos.map((photo: string) => (
          <img src={`${base}photos/${photo}`} alt={d.name} />
        ))}
      </section>
    )}

    <section class="stats">
      <h2>Stats</h2>
      <div class="stat-grid">
        {d.og && <div><strong>OG</strong><span>{d.og}</span></div>}
        {d.fg && <div><strong>FG</strong><span>{d.fg}</span></div>}
        {abv != null && <div><strong>ABV</strong><span>{abv}%</span></div>}
        {ibu != null && <div><strong>IBU</strong><span>{ibu}</span></div>}
        {srm != null && (
          <div>
            <strong>SRM</strong>
            <span class="srm-value">
              {srm}
              <span class="srm-swatch" style={`background:${srmColor}`} />
            </span>
          </div>
        )}
      </div>

      {d.brew_date && <p><strong>Brew Date:</strong> {d.brew_date}</p>}
      {d.bottle_date && <p><strong>Bottle Date:</strong> {d.bottle_date}</p>}
      {d.fermentation && (
        <p>
          <strong>Fermentation:</strong>
          {d.fermentation.temp_celsius && ` ${d.fermentation.temp_celsius}°C`}
          {d.fermentation.duration_days && ` / ${d.fermentation.duration_days} days`}
        </p>
      )}
    </section>

    <section class="ingredients">
      <h2>Ingredients</h2>

      <h3>Malts ({totalGrainKg.toFixed(2)} kg)</h3>
      <table>
        <thead><tr><th>Name</th><th>Weight</th><th>%</th></tr></thead>
        <tbody>
          {d.ingredients.malts.map((m: { name: string; weight_kg: number }) => (
            <tr>
              <td>{m.name}</td>
              <td>{m.weight_kg} kg</td>
              <td>{Math.round(m.weight_kg / totalGrainKg * 100)}%</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h3>Hops</h3>
      <table>
        <thead><tr><th>Name</th><th>Weight</th><th>Time</th><th>Use</th><th>AA%</th></tr></thead>
        <tbody>
          {d.ingredients.hops.map((h: { name: string; weight_g: number; time_min: number; use: string; alpha_acid_pct?: number }) => (
            <tr>
              <td>{h.name}</td>
              <td>{h.weight_g}g</td>
              <td>{h.use === 'dryhop' ? `${h.time_min}d` : `${h.time_min}min`}</td>
              <td>{h.use}</td>
              <td>{h.alpha_acid_pct ?? '-'}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h3>Yeast</h3>
      <p>{d.ingredients.yeast.name} — {d.ingredients.yeast.amount}</p>
    </section>

    {d.process && (
      <section class="process">
        <h2>Process</h2>
        <dl>
          {d.process.mash_temp_celsius && (
            <><dt>Mash</dt><dd>{d.process.mash_temp_celsius}°C / {d.process.mash_duration_min}min</dd></>
          )}
          {d.process.strike_water_liters && (
            <><dt>Strike Water</dt><dd>{d.process.strike_water_liters}L @ {d.process.strike_water_temp_celsius}°C</dd></>
          )}
          {d.process.sparge_water_liters && (
            <><dt>Sparge Water</dt><dd>{d.process.sparge_water_liters}L @ {d.process.sparge_water_temp_celsius}°C</dd></>
          )}
          {d.process.preboil_volume_liters && (
            <><dt>Pre-boil Volume</dt><dd>{d.process.preboil_volume_liters}L</dd></>
          )}
          <dt>Boil</dt><dd>{d.process.boil_duration_min}min</dd>
        </dl>
      </section>
    )}

    {d.cost && d.cost.total_krw && (
      <section class="cost">
        <h2>Cost</h2>
        <p><strong>Total:</strong> {d.cost.total_krw.toLocaleString()} KRW</p>
        {d.cost.breakdown.length > 0 && (
          <table>
            <thead><tr><th>Item</th><th>Cost</th></tr></thead>
            <tbody>
              {d.cost.breakdown.map((b: { item: string; cost_krw: number }) => (
                <tr><td>{b.item}</td><td>{b.cost_krw.toLocaleString()} KRW</td></tr>
              ))}
            </tbody>
          </table>
        )}
      </section>
    )}

    {d.gravity_readings && d.gravity_readings.length > 0 && (
      <section>
        <h2>Gravity Readings</h2>
        <table>
          <thead><tr><th>Day</th><th>Date</th><th>SG</th><th></th></tr></thead>
          <tbody>
            {d.gravity_readings.map((r: { day: number; date: string; sg: number; note?: string }) => (
              <tr>
                <td>{r.day === 0 ? '0' : `+${r.day}`}</td>
                <td>{r.date}</td>
                <td>{r.sg}</td>
                <td class="note">{r.note ?? ''}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {d.tasting_notes && (
      <section>
        <h2>Tasting Notes</h2>
        <p>{d.tasting_notes}</p>
      </section>
    )}

    {d.brew_notes && (
      <section>
        <h2>Brew Notes</h2>
        <p set:html={d.brew_notes.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank">$1</a>')} />
      </section>
    )}

    {Content && (
      <section class="body">
        <Content />
      </section>
    )}
  </article>
</Base>

<style>
  article { max-width: 800px; }
  .back {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  h1 { font-size: 2rem; color: #8b4513; margin-bottom: 0.25rem; }
  .meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    color: #666;
    margin-bottom: 0.75rem;
  }
  .badge {
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }
  .badge[data-status="planned"] { background: #6c757d; }
  .badge[data-status="fermenting"] { background: #e67e22; }
  .badge[data-status="conditioning"] { background: #f39c12; }
  .badge[data-status="ready"] { background: #27ae60; }
  .badge[data-status="archived"] { background: #95a5a6; }
  .source-link {
    background: #fff8e7;
    border-left: 4px solid #d4a574;
    padding: 0.6rem 0.9rem;
    margin: 0.75rem 0;
    border-radius: 4px;
    font-size: 0.95rem;
  }
  .source-link a { font-weight: 600; }
  .collab-section {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .collab-badge {
    background: #3498db;
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .collab-tag {
    background: #eaf2fb;
    color: #2980b9;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
  }
  .collab-tag:hover { background: #d4e6f7; }
  .photos {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .photos img {
    max-width: 400px;
    max-height: 300px;
    object-fit: cover;
    border-radius: 8px;
  }
  section { margin-bottom: 2rem; }
  h2 {
    font-size: 1.3rem;
    color: #8b4513;
    border-bottom: 1px solid #e0d5c7;
    padding-bottom: 0.3rem;
    margin-bottom: 0.75rem;
  }
  h3 { font-size: 1rem; margin: 0.75rem 0 0.5rem; color: #555; }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0.75rem;
  }
  th, td {
    padding: 0.4rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid #eee;
  }
  th { font-weight: 600; color: #666; font-size: 0.85rem; }
  .stat-grid {
    display: flex;
    gap: 2rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .stat-grid div {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .stat-grid strong { font-size: 0.8rem; color: #888; }
  .stat-grid span { font-size: 1.2rem; font-weight: 600; }
  .srm-value { display: flex; align-items: center; gap: 0.4rem; }
  .srm-swatch {
    display: inline-block;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.15);
  }
  dl { display: grid; grid-template-columns: auto 1fr; gap: 0.4rem 1rem; }
  dt { font-weight: 600; color: #666; }
  .note { font-size: 0.8rem; color: #999; }
  .body { border-top: 1px solid #e0d5c7; padding-top: 1rem; }
  .body :global(h1) { font-size: 1.5rem; color: #8b4513; margin-top: 1.5rem; }
  .body :global(h2) { font-size: 1.3rem; color: #8b4513; border-bottom: 1px solid #e0d5c7; padding-bottom: 0.3rem; margin: 1.5rem 0 0.75rem; }
  .body :global(h3) { font-size: 1.05rem; color: #555; margin: 1rem 0 0.4rem; }
  .body :global(blockquote) { border-left: 3px solid #d4a574; padding: 0.4rem 0.9rem; margin: 0.75rem 0; color: #666; background: #fffaf0; }
  .body :global(table) { width: 100%; border-collapse: collapse; margin: 0.75rem 0; }
  .body :global(th), .body :global(td) { padding: 0.4rem 0.75rem; border-bottom: 1px solid #eee; text-align: left; }
  .body :global(th) { font-weight: 600; color: #666; font-size: 0.85rem; }
  .body :global(ul), .body :global(ol) { padding-left: 1.5rem; margin: 0.5rem 0; }
  .body :global(li) { margin: 0.25rem 0; }
  .body :global(code) { background: #f4ecdf; padding: 0.1rem 0.35rem; border-radius: 3px; font-size: 0.9em; }
</style>
